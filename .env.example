# Copiez ce fichier en .env et renseignez votre propre cle (ne jamais commiter .env !)
GROQ_API_KEY=groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# API Legifrance / PISTE (agent recuperateur de reference - optionnel).
# Inscription gratuite : https://piste.gouv.fr/registration
# Puis creer une application (sandbox suffit) et recuperer Client ID / Secret
# dans l'onglet "Applications". Si ces deux variables restent vides,
# l'assistant fonctionne normalement sans la verification en direct.
PISTE_CLIENT_ID=cliend_ID
PISTE_CLIENT_SECRET=client_secret
PISTE_SANDBOX=true